{
    "info": {
        "name": "Workflow IA (Serverless)",
        "description": "Colección de pruebas para endpoints Serverless del Agente IA.\n\nEl endpoint /workflow ahora acepta archivos PDF vía multipart/form-data (recomendado) en lugar de base64 dentro de JSON.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Registro de Usuario",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Juan Perez\",\n    \"email\": \"juan.perez@example.com\",\n    \"password\": \"secure123\"\n}"
                },
                "url": {
                    "raw": "{{api_url}}/register",
                    "host": [
                        "{{api_url}}"
                    ],
                    "path": [
                        "register"
                    ]
                }
            }
        },
        {
            "name": "2. Login de Usuario",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"juan.perez@example.com\",\n    \"password\": \"secure123\"\n}"
                },
                "url": {
                    "raw": "{{api_url}}/login",
                    "host": [
                        "{{api_url}}"
                    ],
                    "path": [
                        "login"
                    ]
                }
            }
        },
        {
            "name": "3. Listar Resultados",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwt_token}}"
                    }
                ],
                "url": {
                    "raw": "{{api_url}}/results",
                    "host": [
                        "{{api_url}}"
                    ],
                    "path": [
                        "results"
                    ]
                }
            }
        },
        {
            "name": "4. Iniciar Workflow IA (form-data)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwt_token}}"
                    }
                ],
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "files",
                            "description": "Archivo PDF a evaluar. Puedes agregar mas filas con la misma key 'files' para enviar multiples PDFs.",
                            "type": "file",
                            "src": []
                        },
                        {
                            "key": "instructions_path",
                            "value": "",
                            "description": "(Opcional) Ruta S3 de las instrucciones. Si se omite, se usa la variable de entorno S3_INSTRUCTIONS_PATH del servidor.",
                            "type": "text",
                            "disabled": true
                        }
                    ]
                },
                "url": {
                    "raw": "{{api_url}}/workflow",
                    "host": [
                        "{{api_url}}"
                    ],
                    "path": [
                        "workflow"
                    ]
                },
                "description": "Sube uno o mas archivos PDF usando form-data.\n\n**Pasos:**\n1. En la pestaña Body, selecciona 'form-data'.\n2. Agrega una fila con key = 'files', tipo = File, y selecciona tu PDF.\n3. Para multiples archivos, agrega mas filas con la misma key 'files'.\n4. (Opcional) Habilita 'instructions_path' si quieres sobreescribir la ruta de instrucciones S3.\n\n**Nota:** No pongas Content-Type en los headers manualmente; Postman lo genera automáticamente con el boundary correcto."
            }
        }
    ],
    "variable": [
        {
            "key": "api_url",
            "value": "https://xyz123.execute-api.us-east-1.amazonaws.com"
        },
        {
            "key": "jwt_token",
            "value": "INSERTA_TU_TOKEN_AQUI"
        }
    ]
}
